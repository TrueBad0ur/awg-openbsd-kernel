+void
+process_awg_commands(void)
+{
+	if (actions & A_AMNEZIAWG) {
+		strlcpy(awgdata.wgd_name, ifname, sizeof(awgdata.wgd_name));
+
+		if (ioctl(sock, SIOCSAWG, (caddr_t)&awgdata) == -1)
+			err(1, "%s: SIOCSAWG", awgdata.wgd_name);
+	}
+}
