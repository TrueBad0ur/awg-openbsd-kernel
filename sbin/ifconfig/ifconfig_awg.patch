+/* AmneziaWG implementation */
+
+#define AWG_BASE64_KEY_LEN (4 * ((AWG_KEY_LEN + 2) / 3))
+#define AWG_LOAD_KEY(dst, src, fn_name) do {				\
+	uint8_t _tmp[AWG_KEY_LEN]; int _r;				\
+	if (strlen(src) != AWG_BASE64_KEY_LEN)				\
+		errx(1, fn_name " (key): invalid length");		\
+	if ((_r = b64_pton(src, _tmp, sizeof(_tmp))) != sizeof(_tmp))	\
+		errx(1, fn_name " (key): invalid base64 %d/%zu", _r, sizeof(_tmp)); \
+	memcpy(dst, _tmp, AWG_KEY_LEN);					\
+} while (0)
+
+struct awg_data_io	 awgdata = { 0 };
+struct awg_interface_io	*awgi_interface = NULL;
+struct awg_peer_io	*awgi_peer = NULL;
+struct awg_aip_io	*awgi_aip = NULL;
+
+void
+ensureawginterface(void)
+{
+	if (awgi_interface != NULL)
+		return;
+	awgdata.wgd_size = sizeof(*awgi_interface);
+	awgdata.wgd_interface = awgi_interface = calloc(1, awgdata.wgd_size);
+	if (awgi_interface == NULL)
+		err(1, "calloc");
+}
+
+void
+growawgdata(size_t by)
+{
+	ptrdiff_t peer_offset, aip_offset;
+
+	if (awgi_interface == NULL)
+		awgdata.wgd_size = sizeof(*awgi_interface);
+
+	peer_offset = (void *)awgi_peer - (void *)awgi_interface;
+	aip_offset = (void *)awgi_aip - (void *)awgi_interface;
+
+	awgdata.wgd_size += by;
+	awgdata.wgd_interface = realloc(awgi_interface, awgdata.wgd_size);
+	if (awgdata.wgd_interface == NULL)
+		err(1, "calloc");
+	if (awgi_interface == NULL)
+		bzero(awgdata.wgd_interface, sizeof(*awgi_interface));
+	awgi_interface = awgdata.wgd_interface;
+
+	if (awgi_peer != NULL)
+		awgi_peer = (void *)awgi_interface + peer_offset;
+	if (awgi_aip != NULL)
+		awgi_aip = (void *)awgi_interface + aip_offset;
+
+	bzero((char *)awgi_interface + awgdata.wgd_size - by, by);
+}
+
+void
+setawgpeer(const char *peerkey_b64, int param)
+{
+	growawgdata(sizeof(*awgi_peer));
+	if (awgi_aip)
+		awgi_peer = (struct awg_peer_io *)awgi_aip;
+	else
+		awgi_peer = &awgi_interface->i_peers[0];
+	awgi_aip = &awgi_peer->p_aips[0];
+	awgi_peer->p_flags |= AWG_PEER_HAS_PUBLIC;
+	AWG_LOAD_KEY(awgi_peer->p_public, peerkey_b64, "awgpeer");
+	awgi_interface->i_peers_count++;
+}
+
+void
+setawgpeerdesc(const char *descr, int param)
+{
+	if (awgi_peer == NULL)
+		errx(1, "awgdescr: awgpeer not set");
+	awgi_peer->p_flags |= AWG_PEER_SET_DESCRIPTION;
+	strlcpy(awgi_peer->p_description, descr, IFDESCRSIZE);
+}
+
+void
+setawgpeeraip(const char *aip, int param)
+{
+	int res;
+	if (awgi_peer == NULL)
+		errx(1, "awgaip: awgpeer not set");
+
+	growawgdata(sizeof(*awgi_aip));
+
+	if ((res = inet_net_pton(AF_INET, aip, &awgi_aip->a_ipv4,
+	    sizeof(awgi_aip->a_ipv4))) != -1) {
+		awgi_aip->a_af = AF_INET;
+	} else if ((res = inet_net_pton(AF_INET6, aip, &awgi_aip->a_ipv6,
+	    sizeof(awgi_aip->a_ipv6))) != -1) {
+		awgi_aip->a_af = AF_INET6;
+	} else {
+		errx(1, "awgaip: bad address");
+	}
+
+	awgi_aip->a_cidr = res;
+
+	awgi_peer->p_flags |= AWG_PEER_REPLACE_AIPS;
+	awgi_peer->p_aips_count++;
+
+	awgi_aip++;
+}
+
+void
+setawgpeerep(const char *host, const char *service)
+{
+	int error;
+	struct addrinfo *ai;
+
+	if (awgi_peer == NULL)
+		errx(1, "awgendpoint: awgpeer not set");
+
+	if ((error = getaddrinfo(host, service, NULL, &ai)) != 0)
+		errx(1, "%s", gai_strerror(error));
+
+	awgi_peer->p_flags |= AWG_PEER_HAS_ENDPOINT;
+	memcpy(&awgi_peer->p_sa, ai->ai_addr, ai->ai_addrlen);
+	freeaddrinfo(ai);
+}
