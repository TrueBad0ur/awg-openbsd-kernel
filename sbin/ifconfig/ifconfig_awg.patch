+void
+awg_status(int ifaliases)
+{
+	size_t			 i, j, last_size;
+	struct timespec		 now;
+	char			 hbuf[NI_MAXHOST], sbuf[NI_MAXSERV];
+	char			 key[AWG_BASE64_KEY_LEN + 1];
+
+	strlcpy(awgdata.wgd_name, ifname, sizeof(awgdata.wgd_name));
+	awgdata.wgd_size = 0;
+	awgdata.wgd_interface = NULL;
+	for (last_size = awgdata.wgd_size;; last_size = awgdata.wgd_size) {
+		if (ioctl(sock, SIOCGAWG, (caddr_t)&awgdata) < 0) {
+			if (errno == ENOTTY)
+				goto out;
+			err(1, "%s: SIOCGAWG", awgdata.wgd_name);
+		}
+		if (last_size >= awgdata.wgd_size)
+			break;
+		awgdata.wgd_interface = realloc(awgdata.wgd_interface,
+		    awgdata.wgd_size);
+		if (!awgdata.wgd_interface)
+			err(1, "realloc");
+	}
+	awgi_interface = awgdata.wgd_interface;
+
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_PORT)
+		printf("\tawgport %hu\n", awgi_interface->i_port);
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_RTABLE)
+		printf("\tawgrtable %d\n", awgi_interface->i_rtable);
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_PUBLIC) {
+		b64_ntop(awgi_interface->i_public, AWG_KEY_LEN,
+		    key, sizeof(key));
+		printf("\tawgpubkey %s\n", key);
+	}
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_JC)
+		printf("\tawgjc %u awgjmin %u awgjmax %u\n",
+		    awgi_interface->i_jc, awgi_interface->i_jmin,
+		    awgi_interface->i_jmax);
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_S12)
+		printf("\tawgs1 %u awgs2 %u\n",
+		    awgi_interface->i_s1, awgi_interface->i_s2);
+	if (awgi_interface->i_flags & AWG_INTERFACE_HAS_H)
+		printf("\tawgh1 %u awgh2 %u awgh3 %u awgh4 %u\n",
+		    awgi_interface->i_h1, awgi_interface->i_h2,
+		    awgi_interface->i_h3, awgi_interface->i_h4);
+
+	if (ifaliases) {
+		awgi_peer = &awgi_interface->i_peers[0];
+		for (i = 0; i < awgi_interface->i_peers_count; i++) {
+			b64_ntop(awgi_peer->p_public, AWG_KEY_LEN,
+			    key, sizeof(key));
+			printf("\tawgpeer %s\n", key);
+
+			if (strlen(awgi_peer->p_description))
+				printf("\t\tawgdescr: %s\n",
+				    awgi_peer->p_description);
+
+			if (awgi_peer->p_flags & AWG_PEER_HAS_PSK)
+				printf("\t\tawgpsk (present)\n");
+
+			if (awgi_peer->p_flags & AWG_PEER_HAS_PKA &&
+			    awgi_peer->p_pka)
+				printf("\t\tawgpka %u (sec)\n", awgi_peer->p_pka);
+
+			if (awgi_peer->p_flags & AWG_PEER_HAS_ENDPOINT) {
+				if (getnameinfo(&awgi_peer->p_sa,
+				    awgi_peer->p_sa.sa_len,
+				    hbuf, sizeof(hbuf), sbuf, sizeof(sbuf),
+				    NI_NUMERICHOST | NI_NUMERICSERV) == 0)
+					printf("\t\tawgendpoint %s %s\n", hbuf, sbuf);
+				else
+					printf("\t\tawgendpoint unable to print\n");
+			}
+
+			printf("\t\ttx: %llu, rx: %llu\n",
+			    awgi_peer->p_txbytes, awgi_peer->p_rxbytes);
+
+			if (awgi_peer->p_last_handshake.tv_sec != 0) {
+				clock_gettime(CLOCK_REALTIME, &now);
+				printf("\t\tlast handshake: %lld seconds ago\n",
+				    now.tv_sec -
+				    awgi_peer->p_last_handshake.tv_sec);
+			}
+
+			awgi_aip = &awgi_peer->p_aips[0];
+			for (j = 0; j < awgi_peer->p_aips_count; j++) {
+				inet_ntop(awgi_aip->a_af, &awgi_aip->a_addr,
+				    hbuf, sizeof(hbuf));
+				printf("\t\tawgaip %s/%d\n", hbuf, awgi_aip->a_cidr);
+				awgi_aip++;
+			}
+			awgi_peer = (struct awg_peer_io *)awgi_aip;
+		}
+	}
+out:
+	free(awgdata.wgd_interface);
+}
